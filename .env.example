# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DB_PATH=./data/vps-manager.db

# JWT Secret (ganti dengan random string di production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# WireGuard Configuration
WG_INTERFACE_NAME=wg0
WG_INTERFACE_PORT=51820
WG_SUBNET=10.0.0.0/24
WG_SERVER_ENDPOINT=your-server-ip:51820

# Default Admin Credentials (ganti setelah install pertama kali)
DEFAULT_ADMIN_EMAIL=admin@vps-manager.local
DEFAULT_ADMIN_PASSWORD=Admin123!

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Audit Log Retention (days)
AUDIT_LOG_RETENTION_DAYS=90
